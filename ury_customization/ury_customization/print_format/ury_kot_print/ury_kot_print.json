 "disabled": 0,
 "doc_type": "URY KOT",
 "docstatus": 0,
 "doctype": "Print Format",
 "font": "Default",
 "font_size": 0,
 "html": "<style>\r\n  /* Reset Frappe default print borders */\r\n  .kot-wrap table, .kot-wrap td, .kot-wrap th {\r\n    border: none !important;\r\n    border-collapse: collapse;\r\n  }\r\n\r\n  .kot-wrap {\r\n    font-family: Arial, sans-serif;\r\n    max-width: 280px;\r\n    margin: 0 auto;\r\n    padding: 6px 4px;\r\n    font-size: 13px;\r\n    color: #000;\r\n  }\r\n  .kot-wrap h1 {\r\n    text-align: center;\r\n    font-size: 20px;\r\n    margin: 0 0 2px 0;\r\n    letter-spacing: 1px;\r\n  }\r\n  .kot-wrap h2 {\r\n    text-align: center;\r\n    font-size: 15px;\r\n    margin: 0 0 4px 0;\r\n    font-weight: normal;\r\n  }\r\n  .divider       { border-top: 1px dashed #000 !important; margin: 5px 0; }\r\n  .divider-solid { border-top: 2px solid #000 !important;  margin: 5px 0; }\r\n  .info-table { width: 100%; }\r\n  .info-table td.lbl {\r\n    font-weight: bold;\r\n    white-space: nowrap;\r\n    padding: 2px 4px 2px 0;\r\n    width: 1%;\r\n  }\r\n  .info-table td.val {\r\n    padding: 2px 0;\r\n  }\r\n  .order-type {\r\n    text-align: center;\r\n    font-size: 13px;\r\n    font-weight: bold;\r\n    padding: 3px 6px;\r\n    margin: 4px 0;\r\n    border-radius: 3px;\r\n  }\r\n  .type-modified  { border: 1px solid #ffc107 !important; background: #fff3cd; }\r\n  .type-cancelled { border: 1px solid #dc3545 !important; background: #f8d7da; }\r\n  .type-duplicate { border: 1px solid #17a2b8 !important; background: #d1ecf1; }\r\n  .items-table { width: 100%; margin-top: 4px; }\r\n  .items-table th {\r\n    border-bottom: 1px solid #000 !important;\r\n    padding: 2px 2px;\r\n    text-align: left;\r\n    font-size: 13px;\r\n  }\r\n  .items-table th.qty { text-align: right; }\r\n  .items-table td { padding: 3px 2px 1px 2px; vertical-align: top; font-size: 13px; }\r\n  .items-table td.qty { text-align: right; font-weight: bold; }\r\n  .item-comment { font-size: 11px; color: #444; }\r\n  .cancelled-row { text-decoration: line-through; color: #888; }\r\n  .footer { text-align: center; font-size: 11px; margin-top: 2px; color: #666; }\r\n</style>\r\n\r\n<div class=\"kot-wrap\">\r\n\r\n  <h1>KITCHEN ORDER</h1>\r\n  <h2>{{ doc.name }}</h2>\r\n  <div class=\"divider-solid\"></div>\r\n\r\n  <table class=\"info-table\">\r\n    <tr>\r\n      <td class=\"lbl\">Order #</td>\r\n      <td class=\"val\">{{ doc.order_no or doc.invoice[-4:] }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"lbl\">Date</td>\r\n      <td class=\"val\">{{ doc.date }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"lbl\">Time</td>\r\n      <td class=\"val\">{{ (doc.time | string)[:8] }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"lbl\">Station</td>\r\n      <td class=\"val\">{{ doc.production or '-' }}</td>\r\n    </tr>\r\n    <tr>\r\n      <td class=\"lbl\">Table</td>\r\n      <td class=\"val\">\r\n        {% if doc.table_takeaway %}<b>TAKEAWAY</b>\r\n        {% elif doc.restaurant_table %}{{ doc.restaurant_table }}\r\n        {% else %}-{% endif %}\r\n      </td>\r\n    </tr>\r\n    {% if doc.customer_name %}\r\n    <tr>\r\n      <td class=\"lbl\">Customer</td>\r\n      <td class=\"val\">{{ doc.customer_name }}</td>\r\n    </tr>\r\n    {% endif %}\r\n  </table>\r\n\r\n  {% if doc.type != 'New Order' %}\r\n    {% if doc.type == 'Order Modified' %}\r\n      <div class=\"order-type type-modified\">*** ORDER MODIFIED ***</div>\r\n    {% elif doc.type == 'Cancelled' %}\r\n      <div class=\"order-type type-cancelled\">*** CANCELLED ***</div>\r\n    {% elif doc.type == 'Partially cancelled' %}\r\n      <div class=\"order-type type-cancelled\">*** PARTIALLY CANCELLED ***</div>\r\n    {% elif doc.type == 'Duplicate' %}\r\n      <div class=\"order-type type-duplicate\">*** DUPLICATE ***</div>\r\n    {% endif %}\r\n  {% endif %}\r\n\r\n  <div class=\"divider\"></div>\r\n\r\n  <table class=\"items-table\">\r\n    <thead>\r\n      <tr>\r\n        <th>Item</th>\r\n        <th class=\"qty\">Qty</th>\r\n      </tr>\r\n    </thead>\r\n    <tbody>\r\n      {% for item in doc.kot_items %}\r\n      <tr class=\"{{ 'cancelled-row' if doc.type == 'Cancelled' else '' }}\">\r\n        <td>\r\n          {{ item.item_name }}\r\n          {% if item.indicate_course and item.course %}\r\n            <br><span class=\"item-comment\">({{ item.course }})</span>\r\n          {% endif %}\r\n          {% if item.comments %}\r\n            <br><span class=\"item-comment\">&#9658; {{ item.comments }}</span>\r\n          {% endif %}\r\n        </td>\r\n        <td class=\"qty\">\r\n          {% if doc.type == 'Partially cancelled' %}\r\n            {{ (item.quantity | int) - (item.cancelled_qty | int) }}\r\n            <br><small style=\"text-decoration:line-through;color:#999\">{{ item.quantity }}</small>\r\n          {% else %}\r\n            {{ item.quantity }}\r\n          {% endif %}\r\n        </td>\r\n      </tr>\r\n      {% endfor %}\r\n    </tbody>\r\n  </table>\r\n\r\n  {% if doc.comments %}\r\n    <div class=\"divider\"></div>\r\n    <p style=\"margin:3px 0;font-size:12px\"><b>Note:</b> {{ doc.comments }}</p>\r\n  {% endif %}\r\n\r\n  <div class=\"divider-solid\"></div>\r\n  <p class=\"footer\">{{ doc.user or '' }}</p>\r\n\r\n</div>\r\n",
 "idx": 0,
